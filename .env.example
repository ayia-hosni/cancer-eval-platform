# ── Infrastructure ────────────────────────────────────────────────────────
POSTGRES_DB=cancer_platform
POSTGRES_USER=cancer_user
POSTGRES_PASSWORD=change_me_never_commit_real_passwords

MONGO_INITDB_ROOT_USERNAME=cancer_user
MONGO_INITDB_ROOT_PASSWORD=change_me

REDIS_URL=redis://redis:6379

# ── Kafka ─────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=kafka:9092

# ── Spring Boot services ──────────────────────────────────────────────────
DB_URL=jdbc:postgresql://postgres:5432/cancer_platform
DB_USER=cancer_user
DB_PASS=change_me

MONGO_URI=mongodb://cancer_user:change_me@mongodb:27017/cancer_results?authSource=admin

# ── ML services ───────────────────────────────────────────────────────────
MODEL_VERSION=v1.0.0
ML_TIMEOUT_SECONDS=15

# ── Notification thresholds ───────────────────────────────────────────────
RISK_THRESHOLD_HIGH=0.75
RISK_THRESHOLD_CRITICAL=0.90

# ── HIPAA / Audit ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUDIT_HMAC_KEY=generate_a_strong_random_key_here

# ── Optional integrations (prod only) ────────────────────────────────────
# SENDGRID_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
